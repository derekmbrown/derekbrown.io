---
import Main from '../../layouts/Main.astro'

const allPosts = await Astro.glob('./../posts/*.md')
const tags = [...new Set(allPosts.map((post) => post.frontmatter.tags).flat())]
tags.sort()
---

<Main 
  PageName="Tags"
  TabTitle="Tags",
  MetaTitle="Derek Brown", 
  MetaDescription="Developer profile, portfolio and blog of Derek Brown.", 
  MetaTag="website", 
  MetaUrl="https://derekbrown.io"
>
  <div class="flex text-5xl font-black mb-7">Tags</div>

  <div class="mb-6">Search for posts using these tags.</div>
  <div class="flex flex-wrap text-2xl">
    {tags.map(tag => (
      <a href={`/tags/${tag}`} class="font-semibold bg-gray-300 mr-3 mb-3 py-1.5 px-3 border-gray-300 border-2 tagHover">
        {tag}
      </a>
    ))}
  </div>
</Main>
